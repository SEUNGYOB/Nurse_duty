# 서버가 바인딩할 주소 (외부 공개 시 0.0.0.0 유지)
HOST=0.0.0.0

# 서버 포트 (공유기 포트포워딩과 맞춰야 함)
PORT=3000

# 파일 업로드 최대 크기 (MB)
MAX_UPLOAD_MB=10

# 허용할 Origin 목록 (콤마 구분, * 는 전체 허용)
# 운영 시에는 Vercel 도메인으로 좁힐 것
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=*

# API 토큰 (비워두면 인증 없이 동작)
# 운영 전에 반드시 설정할 것: openssl rand -hex 32
API_TOKEN=
