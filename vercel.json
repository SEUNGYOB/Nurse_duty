{
  "functions": {
    "api/parse-duty.py": {
      "maxDuration": 120,
      "memory": 1024
    },
    "api/share.py": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/ics.py": {
      "maxDuration": 10,
      "memory": 256
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "microphone=(), geolocation=()" }
      ]
    }
  ]
}
